# --- API Keys (Required for AI Agents) ---
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# LangChain (Optional): https://smith.langchain.com/
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langchain_api_key_here

# --- Local Infrastructure (Managed by docker-compose) ---
# These are the default values if not set
# REDIS_URL=redis://agent-redis:6379/0
# QDRANT_HOST=agent-qdrant
# QDRANT_PORT=6333

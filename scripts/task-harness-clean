#!/usr/bin/env bash
# Deep clean: stop infrastructure, remove volumes, remove toolchain containers/image, and verify.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib/common.sh
source "${SCRIPT_DIR}/lib/common.sh"

GLOBAL_MODE=0
if [[ -n "${AI_HARNESS_HOME:-}" ]]; then
  if [[ "${SCRIPT_DIR}" == "${AI_HARNESS_HOME}/scripts" ]]; then
    GLOBAL_MODE=1
  fi
fi

COMPOSE_ARGS=()
if [[ "${GLOBAL_MODE}" -eq 1 ]]; then
  COMPOSE_ARGS+=("--harness-global")
fi

echo "[harness-clean] Stopping infrastructure and removing volumes..."
if [[ "${#COMPOSE_ARGS[@]}" -gt 0 ]]; then
  "${SCRIPT_DIR}/compose" "${COMPOSE_ARGS[@]}" down --volumes --remove-orphans
else
  "${SCRIPT_DIR}/compose" down --volumes --remove-orphans
fi

echo "[harness-clean] Removing infrastructure containers..."
for container in agent-redis agent-qdrant; do
  if docker ps -aq --filter "name=^/${container}$" | grep -q .; then
    docker rm -f "${container}" >/dev/null 2>&1 || true
  fi
done

echo "[harness-clean] Removing toolchain containers..."
if docker ps -aq --filter "ancestor=${TOOLCHAIN_IMAGE}" | grep -q .; then
  docker ps -aq --filter "ancestor=${TOOLCHAIN_IMAGE}" | xargs docker rm -f >/dev/null 2>&1 || true
fi

echo "[harness-clean] Removing containers attached to agent-network..."
if docker network inspect agent-network >/dev/null 2>&1; then
  attached_containers="$(docker network inspect agent-network --format '{{range $id, $_ := .Containers}}{{println $id}}{{end}}' 2>/dev/null || true)"
  if [[ -n "${attached_containers}" ]]; then
    echo "${attached_containers}" | xargs docker rm -f >/dev/null 2>&1 || true
  fi
fi

echo "[harness-clean] Removing toolchain image..."
docker image rm "${TOOLCHAIN_IMAGE}" >/dev/null 2>&1 || true

echo "[harness-clean] Verifying no leftover containers..."
if [[ -n "$(docker ps -aq 2>/dev/null)" ]]; then
  echo "[harness-clean] ⚠️  Some containers still exist:"
  docker ps -a
else
  echo "[harness-clean] ✅ No containers remaining."
fi

echo "[harness-clean] Verifying networks..."
if docker network ls --format '{{.Name}}' | grep -qx "agent-network"; then
  endpoints=$(docker network inspect agent-network \
    --format '{{range .Containers}}{{.Name}} {{end}}' 2>/dev/null || true)
  for ep in $endpoints; do
    echo "[harness-clean] Disconnecting endpoint: ${ep}"
    docker network disconnect -f agent-network "${ep}" >/dev/null 2>&1 || true
  done
  docker network rm agent-network >/dev/null 2>&1 || true

  if docker network ls --format '{{.Name}}' | grep -qx "agent-network"; then
    echo "[harness-clean] ⚠️  agent-network still exists."
  else
    echo "[harness-clean] ✅ agent-network removed."
  fi
else
  echo "[harness-clean] ✅ No agent-network found."
fi

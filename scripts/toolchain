#!/usr/bin/env bash
set -euo pipefail

IMAGE="${TOOLCHAIN_IMAGE:-ai-dev-toolchain:latest}"

usage() {
  cat <<'USAGE'
Usage:
  scripts/toolchain shell [project_dir]
  scripts/toolchain run <project_dir> <command...>
  scripts/toolchain versions [project_dir]

Examples:
  scripts/toolchain shell .
  scripts/toolchain shell ~/projects/my-ai-app
  scripts/toolchain run . python --version
  scripts/toolchain versions .
USAGE
}

abs_path() {
  local target="${1:-.}"
  if [[ ! -e "${target}" ]]; then
    mkdir -p "${target}"
  fi

  cd "${target}" >/dev/null 2>&1
  pwd -P
}

docker_args() {
  local project_dir="$1"
  local uid
  local gid
  local user

  uid="$(id -u)"
  gid="$(id -g)"
  user="$(id -un)"

  DOCKER_ARGS=(
    "--rm"
    "-e" "HOST_UID=${uid}"
    "-e" "HOST_GID=${gid}"
    "-e" "HOST_USER=${user}"
    "-v" "${project_dir}:/workspace"
    "-w" "/workspace"
  )

  if [[ -t 0 && -t 1 ]]; then
    DOCKER_ARGS+=("-it")
  fi

  DOCKER_ARGS+=("${IMAGE}")
}

command="${1:-}"
shift || true

case "${command}" in
  shell)
    project_dir="$(abs_path "${1:-.}")"
    docker_args "${project_dir}"
    exec docker run "${DOCKER_ARGS[@]}" bash
    ;;
  run)
    if [[ $# -lt 2 ]]; then
      usage
      exit 2
    fi
    project_dir="$(abs_path "$1")"
    shift
    docker_args "${project_dir}"
    exec docker run "${DOCKER_ARGS[@]}" "$@"
    ;;
  versions)
    project_dir="$(abs_path "${1:-.}")"
    docker_args "${project_dir}"
    exec docker run "${DOCKER_ARGS[@]}" bash -lc \
      'printf "mise: "; mise --version; printf "python: "; python --version; printf "node: "; node --version; printf "pnpm: "; pnpm --version; printf "uv: "; uv --version; printf "git: "; git --version'
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    usage
    exit 2
    ;;
esac

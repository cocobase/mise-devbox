#!/usr/bin/env bash
set -euo pipefail

IMAGE="${TOOLCHAIN_IMAGE:-ai-dev-toolchain:latest}"

usage() {
  cat <<'USAGE'
Usage:
  scripts/toolchain shell [project_dir]
  scripts/toolchain run <project_dir> <command...>
  scripts/toolchain versions [project_dir]

Examples:
  scripts/toolchain shell .
  scripts/toolchain shell ~/projects/my-ai-app
  scripts/toolchain run . python --version
  scripts/toolchain versions .
USAGE
}

abs_path() {
  local target="${1:-.}"
  if [[ ! -e "${target}" ]]; then
    mkdir -p "${target}"
  fi

  cd "${target}" >/dev/null 2>&1
  pwd -P
}

docker_args() {
  local project_dir="$1"
  local uid
  local gid
  local user
  local home

  uid="$(id -u)"
  gid="$(id -g)"
  user="$(id -un)"
  home="${HOME}"

  DOCKER_ARGS=(
    "--rm"
    "-e" "HOST_UID=${uid}"
    "-e" "HOST_GID=${gid}"
    "-e" "HOST_USER=${user}"
    "-v" "${project_dir}:/workspace"
    "-w" "/workspace"
  )

  # --- 2.3 动态环境注入：显式白名单模式 ---
  for key in $(compgen -v); do
    if [[ -n "${!key:-}" ]]; then
      case "${key}" in
        OPENAI_*|ANTHROPIC_*|GOOGLE_*|LANGCHAIN_*|AZURE_*|MISTRAL_*|GROQ_*|COHERE_*|HF_*|*_API_KEY)
          DOCKER_ARGS+=("-e" "${key}")
          ;;
      esac
    fi
  done

  # 基础设施变量透传
  for key in REDIS_URL QDRANT_HOST QDRANT_PORT; do
    if [[ -n "${!key:-}" ]]; then
      DOCKER_ARGS+=("-e" "${key}")
    fi
  done

  # --- 4.2 身份认证透传 ---
  # Git config
  if [[ -f "${home}/.gitconfig" ]]; then
    DOCKER_ARGS+=("-v" "${home}/.gitconfig:/home/${user}/.gitconfig:ro")
  fi

  # GitHub CLI config
  if [[ -d "${home}/.config/gh" ]]; then
    DOCKER_ARGS+=("-v" "${home}/.config/gh:/home/${user}/.config/gh:ro")
  fi

  # SSH agent
  if [[ -n "${SSH_AUTH_SOCK:-}" ]] && [[ -S "${SSH_AUTH_SOCK}" ]]; then
    DOCKER_ARGS+=("-e" "SSH_AUTH_SOCK=${SSH_AUTH_SOCK}")
    DOCKER_ARGS+=("-v" "${SSH_AUTH_SOCK}:${SSH_AUTH_SOCK}:ro")
  fi

  # GPG
  if [[ -d "${home}/.gnupg" ]]; then
    DOCKER_ARGS+=("-v" "${home}/.gnupg:/home/${user}/.gnupg")
  fi

  # --- 4.3 缓存挂载优化 ---
  # pnpm cache
  if [[ -d "${home}/.local/share/pnpm" ]]; then
    DOCKER_ARGS+=("-v" "${home}/.local/share/pnpm:/home/${user}/.local/share/pnpm")
  fi

  # uv cache
  if [[ -d "${home}/.cache/uv" ]]; then
    DOCKER_ARGS+=("-v" "${home}/.cache/uv:/home/${user}/.cache/uv")
  fi

  # Check if agent-network exists and join it
  if docker network inspect agent-network >/dev/null 2>&1; then
    DOCKER_ARGS+=("--network" "agent-network")
  fi

  if [[ -t 0 && -t 1 ]]; then
    DOCKER_ARGS+=("-it")
  fi

  DOCKER_ARGS+=("${IMAGE}")
}

command="${1:-}"
shift || true

case "${command}" in
  shell)
    project_dir="$(abs_path "${1:-.}")"
    docker_args "${project_dir}"
    exec docker run "${DOCKER_ARGS[@]}" bash
    ;;
  run)
    if [[ $# -lt 2 ]]; then
      usage
      exit 2
    fi
    project_dir="$(abs_path "$1")"
    shift
    docker_args "${project_dir}"
    exec docker run "${DOCKER_ARGS[@]}" "$@"
    ;;
  versions)
    project_dir="$(abs_path "${1:-.}")"
    docker_args "${project_dir}"
    exec docker run "${DOCKER_ARGS[@]}" bash -lc \
      'printf "mise: "; mise --version; printf "python: "; python --version; printf "node: "; node --version; printf "pnpm: "; pnpm --version; printf "uv: "; uv --version; printf "git: "; git --version; printf "gh: "; gh --version | head -n 1'
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    usage
    exit 2
    ;;
esac

#!/usr/bin/env bash
set -euo pipefail

missing=0

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

print_mise_install() {
  cat <<'EOF'

mise is required but was not found.

Install mise on macOS:
  brew install mise

Or install with the official script:
  curl https://mise.run | sh

After installation, activate it in your shell. For zsh:
  echo 'eval "$(mise activate zsh)"' >> ~/.zshrc
  exec zsh

Verify:
  mise --version
EOF
}

print_docker_install() {
  cat <<'EOF'

Docker is required but was not found.

Option 1: install Docker Desktop on macOS:
  brew install --cask docker

Or download it from:
  https://www.docker.com/products/docker-desktop/

Option 2: install Colima with Docker CLI:
  brew install colima docker
  colima start --runtime docker --cpu 4 --memory 8

After installation:
  1. Start Docker Desktop or Colima.
  2. Wait until the Docker daemon is running.
  3. Verify:
     docker version
EOF
}

print_docker_daemon_help() {
  if command -v colima >/dev/null 2>&1; then
    cat <<'EOF'

Docker CLI is installed, but Docker daemon is not reachable.

Colima is installed. Start Colima's Docker runtime:
  colima start --runtime docker --cpu 4 --memory 8

Then verify:
  docker version
EOF
  else
    cat <<'EOF'

Docker CLI is installed, but Docker daemon is not reachable.

Start one Docker runtime:

Option 1: Docker Desktop
  open -a Docker

Option 2: Colima
  brew install colima
  colima start --runtime docker --cpu 4 --memory 8

Then verify:
  docker version
EOF
  fi
}

# Check Homebrew (info only, non-blocking)
if ! command -v brew >/dev/null 2>&1; then
  printf "${YELLOW}⚠️  Homebrew not found. Recommended installation:${NC}\n"
  printf '  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"\n\n'
else
  printf "${GREEN}✅ homebrew${NC}: found\n"
fi

# Check mise
if ! command -v mise >/dev/null 2>&1; then
  print_mise_install
  missing=1
else
  mise_version=$(mise --version 2>/dev/null || echo "unknown")
  printf "${GREEN}✅ mise${NC}: %s\n" "${mise_version}"
fi

# Check Docker CLI
if ! command -v docker >/dev/null 2>&1; then
  print_docker_install
  missing=1
# Check Docker Daemon
elif ! docker info >/dev/null 2>&1; then
  print_docker_daemon_help
  missing=1
else
  docker_version=$(docker --version 2>/dev/null || echo "unknown")
  printf "${GREEN}✅ docker${NC}: %s\n" "${docker_version}"
fi

# Check docker compose (v2 plugin or v1 standalone)
if docker compose version >/dev/null 2>&1; then
  compose_version=$(docker compose version --short 2>/dev/null || echo "v2")
  printf "${GREEN}✅ docker compose${NC}: %s\n" "${compose_version}"
elif docker-compose version >/dev/null 2>&1; then
  compose_version=$(docker-compose version --short 2>/dev/null || echo "v1")
  printf "${GREEN}✅ docker-compose${NC}: %s\n" "${compose_version}"
else
  cat <<'EOF'

⚠️  docker compose is required but was not found.

Install on macOS:
  brew install docker-compose

Or install Docker Desktop (includes docker compose v2):
  brew install --cask docker

Verify:
  docker compose version
  # or
  docker-compose version
EOF
  missing=1
fi

if [[ "${missing}" -ne 0 ]]; then
  printf "\n${RED}❌ Host checks failed. Please install the missing components above.${NC}\n"
  exit 1
fi

printf '\n🎉 Host toolchain checks passed.\n'

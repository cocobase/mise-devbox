#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib/common.sh
source "${SCRIPT_DIR}/lib/common.sh"

missing=0

print_mise_install() {
  cat <<'EOF'

mise is required but was not found.

Install mise on macOS:
  brew install mise

Or install with the official script:
  curl https://mise.run | sh

After installation, activate it in your shell. For zsh:
  echo 'eval "$(mise activate zsh)"' >> ~/.zshrc
  exec zsh

Verify:
  mise --version
EOF
}

print_docker_install() {
  cat <<'EOF'

Docker is required but was not found.

Option 1: install Docker Desktop on macOS:
  brew install --cask docker

Or download it from:
  https://www.docker.com/products/docker-desktop/

Option 2: install Colima with Docker CLI:
  brew install colima docker
  colima start --runtime docker --cpu 4 --memory 8

After installation:
  1. Start Docker Desktop or Colima.
  2. Wait until the Docker daemon is running.
  3. Verify:
     docker version
EOF
}

print_docker_daemon_help() {
  if command -v colima >/dev/null 2>&1; then
    cat <<'EOF'

Docker CLI is installed, but Docker daemon is not reachable.

Colima is installed. Start Colima's Docker runtime:
  colima start --runtime docker --cpu 4 --memory 8

Then verify:
  docker version
EOF
  else
    cat <<'EOF'

Docker CLI is installed, but Docker daemon is not reachable.

Start one Docker runtime:

Option 1: Docker Desktop
  open -a Docker

Option 2: Colima
  brew install colima
  colima start --runtime docker --cpu 4 --memory 8

Then verify:
  docker version
EOF
  fi
}

# -----------------------------------------------------------------------------
# Checks
# -----------------------------------------------------------------------------

# 1. Homebrew (info only, non-blocking)
if ! command -v brew >/dev/null 2>&1; then
  log_warn "Homebrew not found. Recommended installation:"
  printf '  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"\n\n'
else
  log_ok "homebrew: found"
fi

# 2. mise
if ! command -v mise >/dev/null 2>&1; then
  print_mise_install
  missing=1
else
  mise_version=$(mise --version 2>/dev/null || echo "unknown")
  log_ok "mise: ${mise_version}"
fi

# 3. Docker CLI + Daemon
if ! command -v docker >/dev/null 2>&1; then
  print_docker_install
  missing=1
elif ! docker info >/dev/null 2>&1; then
  print_docker_daemon_help
  missing=1
else
  docker_version=$(docker --version 2>/dev/null || echo "unknown")
  log_ok "docker: ${docker_version}"
fi

# 4. Docker Compose (v2 plugin or v1 standalone)
if compose_cmd=$(detect_compose_cmd 2>/dev/null); then
  compose_version=$("${compose_cmd}" version --short 2>/dev/null || echo "unknown")
  log_ok "docker compose: ${compose_version} (${compose_cmd})"
else
  log_err "docker compose is required but was not found."
  cat <<'EOF'

Install on macOS:
  brew install docker-compose

Or install Docker Desktop (includes docker compose v2):
  brew install --cask docker

Verify:
  docker compose version
  # or
  docker-compose version
EOF
  missing=1
fi

# -----------------------------------------------------------------------------
# Result
# -----------------------------------------------------------------------------
if [[ "${missing}" -ne 0 ]]; then
  log_err "Host checks failed. Please install the missing components above."
  exit 1
fi

printf '\n🎉 Host toolchain checks passed.\n'
